{
  "name": "revue",
  "version": "0.1.0",
  "description": "Revue — a web UI for reviewing patches in git worktrees",
  "bin": {
    "revue": "./bin/revue.js"
  },
  "scripts": {
    "test": "jest --testPathPattern=test/ --forceExit --silent",
    "test:watch": "jest --testPathPattern=test/ --watch --forceExit",
    "test:coverage": "jest --testPathPattern=test/ --coverage --forceExit --silent",
    "dev": "nodemon --watch src --watch public --watch bin bin/revue.js"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  },
  "dependencies": {
    "express": "^4.18.0"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^30.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^6.3.0"
  }
}
