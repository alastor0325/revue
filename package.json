{
  "name": "firefox-review",
  "version": "0.1.0",
  "description": "Review Claude-generated Firefox patches in git worktrees",
  "bin": {
    "firefox-review": "./bin/firefox-review.js"
  },
  "scripts": {
    "test": "jest --testPathPattern=test/ --forceExit --silent",
    "test:watch": "jest --testPathPattern=test/ --watch --forceExit",
    "test:coverage": "jest --testPathPattern=test/ --coverage --forceExit --silent"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  },
  "dependencies": {
    "express": "^4.18.0"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "supertest": "^6.3.0"
  }
}
